---
const products = [
  {
    name: "MOONDROP CHU II",
    price: "$19",
    cut: "zinc shell / cheap legend",
    image:
      "https://cn.cdn.moondroplab.com/627128d862c9a44234848dda/64a67decb6354a3471c0d4cd_CHU2.jpg",
  },
  {
    name: "7Hz Zero:2",
    price: "$24",
    cut: "bass bump / clear body",
    image:
      "https://www.theaudiostore.in/cdn/shop/files/7hz-x-crinacle-zero-2-iem-with-mic-orange-44271691333887.webp?v=1744393797&width=900",
  },
  {
    name: "Kiwi Ears Belle",
    price: "$30",
    cut: "black plate / daily carry",
    image:
      "https://kiwiears.com/cdn/shop/files/KiwiEarsBelle_2_08949fc3-017c-4815-a6cb-8caa6ad6a52f.jpg?v=1773412066&width=1200",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Plugged variation one: a dark streetwear IEM storefront with a Three.js cable sculpture."
    />
    <title>Plugged / 1</title>
  </head>
  <body>
    <main class="drop" data-drop>
      <canvas id="plugged-field" aria-hidden="true"></canvas>
      <div class="noise" aria-hidden="true"></div>
      <div class="paper-rips" aria-hidden="true">
        <span>not for bluetooth kids</span>
        <span>plugged audio supply</span>
        <span>drop 001 / no returns after the pit</span>
      </div>

      <header class="topline">
        <a class="seal" href="/" aria-label="Plugged home">
          <img src="/logo.png" alt="" />
          <span>PLUGGED</span>
        </a>
        <nav aria-label="Drop navigation">
          <a href="#drop-board">drop</a>
          <a href="#fit">fit</a>
          <a href="#checkout">bag</a>
        </nav>
      </header>

      <section class="stage" aria-labelledby="title">
        <p class="stamp">underground wired goods / mongrel hi-fi</p>
        <h1 id="title">
          <span>NO SIGNAL</span>
          <span>NO GODS</span>
          <span>JUST CABLE</span>
        </h1>
        <div class="logo-hit" aria-hidden="true">
          <img src="/logo.png" alt="" />
        </div>
        <p class="subcopy">
          Street-level IEMs for the playlist you do not post. Small shells,
          filthy fit, clean pressure.
        </p>
        <a class="primary" href="#drop-board">open the crate</a>
      </section>

      <section class="drop-board" id="drop-board" aria-labelledby="drop-title">
        <div class="board-copy">
          <p class="stamp">new crate smell, old basement lighting</p>
          <h2 id="drop-title">Three wired problems.</h2>
        </div>

        <div class="crate">
          {
            products.map((product, index) => (
              <article class="piece" style={`--turn:${index - 1}; --i:${index}`}>
                <a href="#checkout" class="piece-link">
                  <span class="photo">
                    <img
                      src={product.image}
                      alt={`${product.name} product photo`}
                      loading={index === 0 ? "eager" : "lazy"}
                    />
                  </span>
                  <span class="piece-copy">
                    <small>{product.cut}</small>
                    <strong>{product.name}</strong>
                    <em>{product.price}</em>
                  </span>
                </a>
              </article>
            ))
          }
        </div>
      </section>

      <section class="fit" id="fit" aria-labelledby="fit-title">
        <div>
          <p class="stamp">fit check for the wired</p>
          <h2 id="fit-title">Logo on paper. Cable under hoodie. Volume at the line.</h2>
        </div>
        <div class="manifest">
          <span>01 / no blue light romance</span>
          <span>02 / analog feels richer in bad weather</span>
          <span>03 / if the shell disappears, the song stays</span>
          <span>04 / logo looks best half ruined</span>
        </div>
      </section>

      <section class="checkout" id="checkout" aria-labelledby="checkout-title">
        <img src="/logo.png" alt="" />
        <div>
          <p class="stamp">counter closes when the bass stops</p>
          <h2 id="checkout-title">Leave with something wired.</h2>
          <button type="button" data-shock>shake the wall</button>
        </div>
      </section>
    </main>

    <script is:inline type="module">
      import * as THREE from "https://esm.sh/three@0.167.1";

      const canvas = document.querySelector("#plugged-field");
      const root = document.querySelector("[data-drop]");
      const shock = document.querySelector("[data-shock]");
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(55, 1, 0.1, 120);
      const renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: true,
        antialias: true,
      });

      const pointer = new THREE.Vector2(0, 0);
      const group = new THREE.Group();
      scene.add(group);

      camera.position.set(0, 0.25, 18);

      const cream = new THREE.Color("#e1d8c2");
      const rust = new THREE.Color("#b4512f");
      const black = new THREE.Color("#080706");

      const cableMaterial = new THREE.MeshStandardMaterial({
        color: black,
        roughness: 0.88,
        metalness: 0.18,
      });
      const rustMaterial = new THREE.MeshStandardMaterial({
        color: rust,
        roughness: 0.74,
        metalness: 0.22,
      });
      const paperMaterial = new THREE.MeshBasicMaterial({
        color: cream,
        transparent: true,
        opacity: 0.16,
        side: THREE.DoubleSide,
      });

      const curve = new THREE.CatmullRomCurve3(
        Array.from({ length: 18 }, (_, index) => {
          const t = index / 17;
          const angle = t * Math.PI * 5.5;
          const radius = 5.4 - t * 2.2;
          return new THREE.Vector3(
            Math.cos(angle) * radius,
            Math.sin(angle * 0.92) * radius * 0.62,
            (t - 0.5) * 6,
          );
        }),
      );
      const cable = new THREE.Mesh(
        new THREE.TubeGeometry(curve, 220, 0.055, 10, false),
        cableMaterial,
      );
      group.add(cable);

      for (let i = 0; i < 28; i += 1) {
        const ring = new THREE.Mesh(
          new THREE.TorusGeometry(1.2 + i * 0.09, 0.01, 6, 80),
          i % 4 === 0 ? rustMaterial : paperMaterial,
        );
        ring.position.set((i % 7) - 3, Math.sin(i) * 2.6, -7 + i * 0.38);
        ring.rotation.set(i * 0.17, i * 0.2, i * 0.11);
        group.add(ring);
      }

      const plug = new THREE.Group();
      const plugBody = new THREE.Mesh(
        new THREE.CylinderGeometry(0.34, 0.42, 1.7, 18),
        rustMaterial,
      );
      plugBody.rotation.z = Math.PI / 2;
      plug.add(plugBody);

      for (let i = 0; i < 3; i += 1) {
        const band = new THREE.Mesh(
          new THREE.CylinderGeometry(0.24, 0.24, 0.17, 18),
          new THREE.MeshBasicMaterial({ color: i === 1 ? rust : cream }),
        );
        band.position.x = 0.54 + i * 0.25;
        band.rotation.z = Math.PI / 2;
        plug.add(band);
      }
      plug.position.set(5.6, -1.8, 0.2);
      plug.rotation.set(0.2, -0.3, -0.4);
      group.add(plug);

      const light = new THREE.DirectionalLight("#e1d8c2", 2.2);
      light.position.set(4, 8, 9);
      scene.add(light);
      scene.add(new THREE.AmbientLight("#b4512f", 0.82));

      function size() {
        const width = window.innerWidth;
        const height = window.innerHeight;
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
        renderer.setSize(width, height, false);
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
      }

      function frame(time) {
        const seconds = time * 0.001;
        group.rotation.x = Math.sin(seconds * 0.28) * 0.13 + pointer.y * 0.18;
        group.rotation.y = seconds * 0.11 + pointer.x * 0.28;
        group.rotation.z = Math.sin(seconds * 0.17) * 0.08;
        plug.rotation.x = Math.sin(seconds * 0.9) * 0.15;
        renderer.render(scene, camera);
        requestAnimationFrame(frame);
      }

      window.addEventListener("resize", size);
      window.addEventListener(
        "pointermove",
        (event) => {
          pointer.x = (event.clientX / window.innerWidth - 0.5) * 2;
          pointer.y = -(event.clientY / window.innerHeight - 0.5) * 2;
          root.style.setProperty("--mx", `${event.clientX}px`);
          root.style.setProperty("--my", `${event.clientY}px`);
        },
        { passive: true },
      );
      shock.addEventListener("click", () => {
        root.classList.remove("hit");
        requestAnimationFrame(() => root.classList.add("hit"));
      });

      size();
      requestAnimationFrame(frame);
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --ink: #050403;
    --coal: #100e0b;
    --paper: #e6dcc8;
    --old: #b9aa8e;
    --rust: #b4512f;
    --mud: #3c2a20;
    --line: rgba(230, 220, 200, 0.24);
    font-family:
      "Arial Narrow", "Helvetica Neue", Arial, system-ui, sans-serif;
    background: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--ink);
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    margin: 0;
    overflow-x: hidden;
    background: var(--ink);
    color: var(--paper);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .drop {
    --mx: 50vw;
    --my: 50vh;
    position: relative;
    min-height: 100svh;
    isolation: isolate;
    background:
      radial-gradient(circle at var(--mx) var(--my), rgba(180, 81, 47, 0.2), transparent 24rem),
      repeating-linear-gradient(99deg, rgba(230,220,200,0.026) 0 1px, transparent 1px 14px),
      linear-gradient(118deg, #050403 0%, #15110d 47%, #080604 100%);
  }

  #plugged-field {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100svh;
    opacity: 0.7;
    filter: contrast(1.12) grayscale(0.08);
  }

  .noise,
  .noise::before,
  .noise::after {
    position: fixed;
    inset: 0;
    z-index: 30;
    pointer-events: none;
    content: "";
  }

  .noise {
    opacity: 0.36;
    mix-blend-mode: overlay;
    background-image:
      repeating-radial-gradient(circle at 28% 31%, rgba(255,255,255,0.18) 0 1px, transparent 1px 4px),
      repeating-linear-gradient(91deg, transparent 0 2px, rgba(0,0,0,0.65) 2px 3px);
    animation: dirt 0.55s steps(2) infinite;
  }

  .noise::before {
    opacity: 0.24;
    background:
      linear-gradient(90deg, transparent 0 12%, rgba(230,220,200,0.07) 12% 12.3%, transparent 12.3%),
      repeating-linear-gradient(0deg, transparent 0 5px, rgba(230,220,200,0.08) 5px 6px);
  }

  .noise::after {
    opacity: 0.42;
    background: radial-gradient(circle at center, transparent 0 42%, rgba(0,0,0,0.82) 85%);
  }

  .paper-rips {
    position: fixed;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .paper-rips span {
    position: absolute;
    max-width: 18rem;
    padding: 0.5rem 0.65rem;
    background:
      linear-gradient(90deg, rgba(230,220,200,0.78), rgba(185,170,142,0.56)),
      repeating-linear-gradient(0deg, transparent 0 7px, rgba(5,4,3,0.16) 7px 8px);
    color: var(--ink);
    font-size: clamp(0.8rem, 1.7vw, 1.25rem);
    font-weight: 1000;
    line-height: 0.86;
    text-transform: uppercase;
    opacity: 0.2;
    clip-path: polygon(2% 0, 98% 7%, 94% 100%, 0 88%);
    box-shadow: 0.35rem 0.35rem 0 rgba(0,0,0,0.6);
  }

  .paper-rips span:nth-child(1) {
    top: 13svh;
    left: 6vw;
    transform: rotate(-7deg);
  }

  .paper-rips span:nth-child(2) {
    right: 5vw;
    top: 32svh;
    transform: rotate(5deg);
  }

  .paper-rips span:nth-child(3) {
    left: 45vw;
    bottom: 9svh;
    transform: rotate(-3deg);
  }

  .topline {
    position: fixed;
    inset: 0 0 auto;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem clamp(1rem, 3vw, 2.2rem);
    mix-blend-mode: difference;
  }

  .seal {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .seal img {
    width: 2.7rem;
    aspect-ratio: 1;
    border-radius: 50%;
    object-fit: cover;
    filter: grayscale(0.1) contrast(1.15);
  }

  nav {
    display: flex;
    gap: clamp(0.8rem, 2vw, 1.7rem);
    font-size: 0.78rem;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .stage {
    position: relative;
    z-index: 5;
    min-height: 100svh;
    padding: 7rem clamp(1rem, 5vw, 5rem) 4rem;
    display: grid;
    align-content: end;
  }

  .stamp {
    margin: 0 0 0.85rem;
    color: var(--old);
    font-size: 0.78rem;
    font-weight: 1000;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    display: grid;
    max-width: 72rem;
    margin: 0;
    font-size: clamp(4rem, 11vw, 11.6rem);
    font-weight: 1000;
    line-height: 0.75;
    text-transform: uppercase;
  }

  h1 span {
    width: max-content;
    max-width: 100%;
    background:
      linear-gradient(180deg, rgba(230,220,200,1), rgba(185,170,142,0.78)),
      repeating-linear-gradient(90deg, transparent 0 0.8rem, rgba(5,4,3,0.14) 0.8rem 0.86rem);
    color: var(--ink);
    padding: 0.03em 0.08em 0.01em;
    filter: drop-shadow(0.08em 0.08em 0 rgba(180,81,47,0.85));
    clip-path: polygon(1% 0, 99% 5%, 96% 100%, 0 91%);
    transform: rotate(calc((var(--n, 1) - 2) * -1deg));
  }

  h1 span:nth-child(2) {
    --n: 2;
    margin-left: clamp(1.8rem, 9vw, 9rem);
  }

  h1 span:nth-child(3) {
    --n: 3;
    margin-left: clamp(0.8rem, 4vw, 4rem);
  }

  .logo-hit {
    position: absolute;
    right: clamp(1rem, 7vw, 8rem);
    top: 15svh;
    width: clamp(12rem, 27vw, 28rem);
    aspect-ratio: 1;
    opacity: 0.84;
    transform: rotate(9deg);
    mix-blend-mode: screen;
  }

  .logo-hit::before {
    position: absolute;
    inset: -0.8rem;
    content: "";
    background: var(--paper);
    clip-path: polygon(6% 2%, 100% 11%, 90% 94%, 0 100%);
    box-shadow: 1rem 1rem 0 rgba(0,0,0,0.72);
  }

  .logo-hit img {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.22) saturate(0.82);
    clip-path: polygon(8% 4%, 98% 10%, 91% 93%, 2% 98%);
  }

  .subcopy {
    width: min(34rem, 100%);
    margin: 1.8rem 0 0;
    color: var(--paper);
    font-size: clamp(1.1rem, 2.4vw, 2.05rem);
    font-weight: 900;
    line-height: 1.02;
  }

  .primary,
  .checkout button {
    width: max-content;
    margin-top: 1.4rem;
    border: 1px solid var(--paper);
    background: var(--rust);
    color: var(--paper);
    padding: 0.85rem 1rem;
    font-weight: 1000;
    text-transform: uppercase;
    box-shadow: 0.35rem 0.35rem 0 rgba(0,0,0,0.8);
    cursor: pointer;
  }

  .drop-board,
  .fit,
  .checkout {
    position: relative;
    z-index: 5;
    padding: clamp(4rem, 9vw, 8rem) clamp(1rem, 5vw, 5rem);
  }

  .board-copy {
    width: min(58rem, 100%);
  }

  h2 {
    margin: 0;
    font-size: clamp(3rem, 9vw, 8rem);
    font-weight: 1000;
    line-height: 0.82;
    text-transform: uppercase;
  }

  .crate {
    display: grid;
    grid-template-columns: 1.05fr 0.82fr 1.13fr;
    gap: clamp(1rem, 3vw, 2.2rem);
    margin-top: clamp(2rem, 6vw, 5rem);
    align-items: end;
  }

  .piece {
    min-height: clamp(28rem, 49vw, 44rem);
    transform: rotate(calc(var(--turn) * 2.4deg));
  }

  .piece-link {
    position: relative;
    display: grid;
    height: 100%;
    min-height: inherit;
    overflow: hidden;
    border: 1px solid var(--line);
    background:
      linear-gradient(180deg, rgba(230,220,200,0.045), transparent 33%),
      repeating-linear-gradient(101deg, transparent 0 1.4rem, rgba(180,81,47,0.09) 1.4rem 1.5rem),
      rgba(5,4,3,0.88);
    box-shadow: 0.8rem 0.8rem 0 rgba(0,0,0,0.56);
  }

  .piece-link::before {
    position: absolute;
    top: 1.2rem;
    left: 50%;
    z-index: 4;
    width: 42%;
    height: 1.2rem;
    content: "";
    background: rgba(230,220,200,0.62);
    transform: translateX(-50%) rotate(-2deg);
  }

  .photo {
    position: absolute;
    inset: 3.5rem 1rem auto;
    display: grid;
    height: 58%;
    place-items: center;
    background:
      linear-gradient(180deg, rgba(230,220,200,0.96), rgba(185,170,142,0.78)),
      repeating-linear-gradient(90deg, rgba(5,4,3,0.12) 0 1px, transparent 1px 1.7rem);
    clip-path: polygon(4% 1%, 98% 9%, 92% 97%, 0 91%);
    box-shadow: 0.7rem 0.8rem 0 rgba(0,0,0,0.7);
  }

  .photo img {
    width: 94%;
    max-height: 92%;
    object-fit: contain;
    filter: contrast(1.1) saturate(0.76) drop-shadow(0.35rem 0.45rem 0 rgba(0,0,0,0.35));
    transition: transform 260ms ease, filter 260ms ease;
  }

  .piece-link:hover .photo img,
  .piece-link:focus-visible .photo img {
    transform: scale(1.08) rotate(-2deg);
    filter: contrast(1.18) saturate(0.92) drop-shadow(0.4rem 0.5rem 0 rgba(0,0,0,0.48));
  }

  .piece-copy {
    position: relative;
    z-index: 4;
    align-self: end;
    display: grid;
    gap: 0.5rem;
    padding: 1rem;
    text-transform: uppercase;
  }

  .piece-copy small,
  .piece-copy em {
    color: color-mix(in srgb, var(--rust), var(--paper) 45%);
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 1000;
  }

  .piece-copy strong {
    font-size: clamp(2rem, 4vw, 4.4rem);
    font-weight: 1000;
    line-height: 0.84;
    overflow-wrap: anywhere;
  }

  .fit {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 30rem);
    gap: clamp(2rem, 8vw, 8rem);
    align-items: end;
    min-height: 100svh;
  }

  .manifest {
    display: grid;
    gap: 0.65rem;
    transform: rotate(3deg);
  }

  .manifest span {
    display: block;
    background: var(--paper);
    color: var(--ink);
    padding: 0.75rem 0.9rem;
    font-size: clamp(1rem, 2vw, 1.45rem);
    font-weight: 1000;
    line-height: 0.95;
    text-transform: uppercase;
    clip-path: polygon(2% 0, 99% 8%, 96% 100%, 0 90%);
    box-shadow: 0.35rem 0.4rem 0 rgba(0,0,0,0.7);
  }

  .checkout {
    display: grid;
    grid-template-columns: minmax(10rem, 22rem) minmax(0, 1fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: center;
    min-height: 80svh;
    background:
      linear-gradient(90deg, rgba(180,81,47,0.18), transparent 44%),
      rgba(10,8,6,0.68);
  }

  .checkout img {
    width: 100%;
    background: var(--paper);
    clip-path: polygon(5% 0, 100% 6%, 90% 100%, 0 93%);
    box-shadow: 1rem 1rem 0 rgba(0,0,0,0.74);
    transform: rotate(-6deg);
  }

  .hit h1 span,
  .hit .piece,
  .hit .checkout img {
    animation: slam 420ms steps(2);
  }

  @keyframes dirt {
    to {
      transform: translate(-2%, 1.4%);
    }
  }

  @keyframes slam {
    35% {
      transform: translate(0.45rem, -0.28rem) rotate(-2deg);
      filter: contrast(1.6);
    }
  }

  @media (max-width: 900px) {
    nav {
      display: none;
    }

    .stage {
      align-content: start;
      padding-top: 7rem;
    }

    .logo-hit {
      position: relative;
      right: auto;
      top: auto;
      width: min(19rem, 76vw);
      margin: 2rem 0 0 auto;
    }

    h1 {
      font-size: clamp(3.3rem, 18vw, 7rem);
    }

    h1 span:nth-child(2),
    h1 span:nth-child(3) {
      margin-left: 0;
    }

    .crate,
    .fit,
    .checkout {
      grid-template-columns: 1fr;
    }

    .piece {
      min-height: 28rem;
      transform: none;
    }

    .photo {
      height: 60%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
