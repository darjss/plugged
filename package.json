{
  "name": "plugged",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "db:generate": "drizzle-kit generate",
    "db:seed:sql": "node scripts/build-iem-seed-sql.mjs",
    "db:seed:remote": "node scripts/build-iem-seed-sql.mjs > /tmp/plugged-iem-seed.sql && wrangler d1 execute plugged --remote --file /tmp/plugged-iem-seed.sql",
    "db:seed:images:sql": "node scripts/build-iem-image-seed-sql.mjs",
    "db:seed:images:remote": "node scripts/build-iem-image-seed-sql.mjs > /tmp/plugged-iem-image-seed.sql && wrangler d1 execute plugged --remote --file /tmp/plugged-iem-image-seed.sql",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "typecheck": "tsgo --project tsconfig.json",
    "check:astro": "astro check",
    "generate-types": "wrangler types",
    "deploy": "astro build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "prepare": "vp config"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "@astrojs/solid-js": "^7.0.0",
    "@corvu/drawer": "^0.2.4",
    "@corvu/otp-field": "^0.1.4",
    "@corvu/resizable": "^0.2.5",
    "@elysiajs/eden": "^1.4.9",
    "@kobalte/core": "^0.13.11",
    "@mendable/firecrawl-js": "^4.28.2",
    "@motionone/dom": "^10.18.0",
    "@motionone/solid": "^10.16.4",
    "@solid-primitives/storage": "^4.3.4",
    "@solidjs/router": "^0.16.1",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/solid-query": "^5.101.0",
    "android-sms-gateway": "^3.0.0",
    "astro": "^7.0.3",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "ky": "^2.0.2",
    "lucide-solid": "^1.21.0",
    "nanoid": "^5.1.15",
    "posthog-js": "^1.393.5",
    "solid-js": "^1.9.11",
    "solid-sonner": "^0.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/bun": "^1.3.14",
    "@types/d3": "^7.4.3",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "drizzle-kit": "^0.31.9",
    "vite-plus": "catalog:",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.8.0"
}
