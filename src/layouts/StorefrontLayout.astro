---
import Layout from "./Layout.astro";
import Header from "../components/storefront/Header.astro";
import Footer from "../components/storefront/Footer.astro";
import MobileNav from "../components/storefront/MobileNav.astro";
import CartDrawer from "../components/storefront/CartDrawer.tsx";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<Layout title={title} description={description}>
  <div class="flex min-h-screen flex-col">
    {/* Skip link for keyboard users */}
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-[100] focus:border-2 focus:border-ink focus:bg-primary focus:px-4 focus:py-3 focus:font-black focus:uppercase focus:tracking-wider focus:shadow-hard"
    >
      Skip to content
    </a>

    <Header />

    <main id="main" class="relative z-10 flex-1 pb-16 md:pb-0">
      <slot />
    </main>

    <Footer />

    {/* Mobile bottom nav */}
    <MobileNav />

    {/* Cart drawer — client:only to avoid SSR/localStorage mismatch.
        No `transition:persist` wrapper: the drawer renders through a
        Solid `<Portal>` into `document.body`, so persisting the wrapper
        would keep the empty shell while the portaled overlay/panel get
        torn down on swap, wedging the user. The drawer closes itself
        on `astro:before-swap` (see CartDrawer.tsx). */}
    <CartDrawer client:only="solid-js" />

    {/* Spacer for mobile bottom nav so content isn't hidden */}
    <div class="h-16 md:hidden" aria-hidden="true"></div>
  </div>
</Layout>
