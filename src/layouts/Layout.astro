---
import { ClientRouter } from "astro:transitions";
import PostHog from "../components/storefront/PostHog";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const {
  title = "Plugged — IEM Audio Store",
  description = "Photocopied zine meets warehouse rave. IEMs, DAC amps, and wireless earbuds.",
  ogTitle,
  ogDescription,
  ogImage = "/logo.png",
  ogUrl,
  ogType = "website",
  canonicalUrl,
} = Astro.props;

const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY;
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST ?? "https://us.posthog.com";

// Absolute canonical + OG URLs. Astro.site is set in astro.config.mjs.
const siteOrigin = Astro.site?.origin ?? "https://pluggedaudio.store";
const absoluteUrl = (value: string | undefined, fallback: string) => {
  if (!value) return new URL(fallback, siteOrigin).href;
  try {
    return new URL(value, siteOrigin).href;
  } catch {
    return new URL(fallback, siteOrigin).href;
  }
};

const canonical = absoluteUrl(canonicalUrl, Astro.url.pathname);
const resolvedOgUrl = absoluteUrl(ogUrl, Astro.url.pathname);
const ogImg = absoluteUrl(ogImage, "/");
const finalOgTitle = ogTitle ?? title;
const finalOgDescription = ogDescription ?? description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:title" content={finalOgTitle} />
    <meta property="og:description" content={finalOgDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedOgUrl} />
    <meta property="og:image" content={ogImg} />
    <meta property="og:site_name" content="Plugged" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalOgTitle} />
    <meta name="twitter:description" content={finalOgDescription} />
    <meta name="twitter:image" content={ogImg} />

    <!-- Fonts: Space Grotesk (sans), Geist Mono (mono), Anton (display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans antialiased">
    <!-- Newsprint grain + scanline overlay is applied via body::before in global.css -->
    <slot />
    <PostHog client:load apiKey={posthogKey} host={posthogHost} />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
