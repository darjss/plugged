---
import StorefrontLayout from "../../../layouts/StorefrontLayout.astro";
import ClearCart from "../../../components/storefront/ClearCart.tsx";
import { api } from "../../../lib/api-client";
import { formatMnt } from "../../../lib/utils";

export const prerender = false;

const { orderNumber } = Astro.params;

// Missing or malformed order number → bounce to products. A real lookup
// miss returns an Eden error response, which we turn into an empty state.
const orderRes = orderNumber
  ? await api.orders({ orderNumber }).get().catch(() => null)
  : null;
const order = orderRes?.data ?? null;
---

<StorefrontLayout title="Order confirmed | Plugged" description="Your order is confirmed.">
  {/* Clear the cart now that the order is placed and paid. */}
  <ClearCart client:only="solid-js" />

  <section class="relative mx-auto max-w-3xl px-4 py-12 lg:px-8">
    {order === null ? (
      <div class="mx-auto flex min-h-[50vh] max-w-md flex-col items-center justify-center gap-4 text-center">
        <div class="flex size-20 items-center justify-center border-4 border-ink bg-pink shadow-hard">
          <span class="font-display text-3xl font-black text-newsprint">?</span>
        </div>
        <h2 class="font-display text-2xl font-black uppercase tracking-tight text-ink">
          Order not found
        </h2>
        <p class="text-sm font-bold text-muted-foreground">
          We couldn't find that order. Check your link or go grab more gear.
        </p>
        <a
          href="/products"
          class="border-2 border-ink bg-orange px-6 py-3 text-sm font-black uppercase tracking-wide text-ink shadow-hard-lg transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-hard"
        >
          Browse products
        </a>
      </div>
    ) : (
      <>
        {/* Masthead — stamped confirmation */}
        <div class="mb-8 flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <span class="rotate-[-3deg] border-2 border-ink bg-orange px-3 py-1.5 font-display text-2xl font-black uppercase tracking-tight text-ink shadow-hard">
              Paid
            </span>
            <span class="font-mono text-xs font-black uppercase tracking-widest text-muted-foreground">
              Receipt / keep this
            </span>
          </div>
          <h1
            class="font-display text-display font-black uppercase leading-none tracking-tight text-ink"
            style="clip-path: polygon(0 0, 100% 0, 99% 100%, 2% 97%);"
          >
            You're plugged in
          </h1>
          <p class="max-w-prose text-body-lg text-muted-foreground">
            Order received. We'll text delivery updates to your phone. Tape this
            page to the fridge.
          </p>
        </div>

        {/* Order number stamp */}
        <div class="mb-6 flex flex-wrap items-center justify-between gap-3 border-2 border-ink bg-newsprint-2 p-4 shadow-hard-lg">
          <div class="flex flex-col">
            <span class="text-micro font-black uppercase tracking-widest text-muted-foreground">
              Order number
            </span>
            <span class="font-mono text-lg font-black text-ink">{order.orderNumber}</span>
          </div>
          <span class="border-2 border-ink bg-yellow px-3 py-1.5 font-mono text-xs font-black uppercase text-ink shadow-hard-sm">
            {order.status}
          </span>
        </div>

        {/* Items */}
        <div class="mb-6 border-2 border-ink bg-card p-5 shadow-hard-lg">
          <h2 class="mb-3 border-b-2 border-ink pb-2 font-display text-xl font-black uppercase tracking-tight text-ink">
            The haul
          </h2>
          <ul class="flex flex-col gap-3">
            {order.items.map((item) => (
              <li class="flex items-center justify-between gap-3 border-2 border-ink bg-newsprint p-3 shadow-hard-sm">
                <div class="min-w-0 flex-1">
                  <p class="truncate font-black uppercase leading-tight text-ink">{item.productName}</p>
                  <p class="font-mono text-xs font-bold text-muted-foreground">
                    {item.variantName} · {item.sku}
                  </p>
                  <p class="font-mono text-xs font-bold text-muted-foreground">
                    {formatMnt(item.unitPriceMnt)} × {item.quantity}
                  </p>
                </div>
                <span class="rotate-1 border-2 border-ink bg-yellow px-2 py-1 font-mono text-sm font-black text-ink shadow-hard-sm">
                  {formatMnt(item.lineTotalMnt)}
                </span>
              </li>
            ))}
          </ul>

          {/* Totals */}
          <div class="mt-4 space-y-1.5 border-t-2 border-ink pt-3">
            <div class="flex items-center justify-between">
              <span class="text-xs font-black uppercase tracking-wide text-muted-foreground">Subtotal</span>
              <span class="font-mono text-sm font-bold text-ink">{formatMnt(order.subtotalMnt)}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs font-black uppercase tracking-wide text-muted-foreground">Delivery</span>
              <span class="font-mono text-sm font-bold text-ink">{formatMnt(order.deliveryFeeMnt)}</span>
            </div>
            <div class="flex items-center justify-between border-t-2 border-ink pt-2">
              <span class="font-black uppercase tracking-wide text-ink">Total paid</span>
              <span class="rotate-1 border-2 border-ink bg-pink px-3 py-1.5 font-mono text-heading font-black text-newsprint shadow-hard-sm">
                {formatMnt(order.totalMnt)}
              </span>
            </div>
          </div>
        </div>

        {/* Delivery address */}
        <div class="mb-6 border-2 border-ink bg-newsprint-2 p-5 shadow-hard-lg">
          <h2 class="mb-2 font-display text-xl font-black uppercase tracking-tight text-ink">
            Ships to
          </h2>
          <p class="font-mono text-sm font-bold text-ink">{order.address}</p>
          <p class="mt-1 font-mono text-xs font-bold text-muted-foreground">
            {order.customerPhone}
            {order.customerName ? ` · ${order.customerName}` : ""}
          </p>
          {order.notes && (
            <p class="mt-2 border-t-2 border-ink pt-2 font-mono text-xs font-bold text-muted-foreground">
              Notes: {order.notes}
            </p>
          )}
        </div>

        {/* Next steps */}
        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="/products"
            class="border-2 border-ink bg-orange px-6 py-3 text-sm font-black uppercase tracking-wide text-ink shadow-hard-lg transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-hard"
          >
            Keep browsing
          </a>
          <a
            href="/"
            class="border-2 border-ink bg-card px-6 py-3 text-sm font-black uppercase tracking-wide text-ink shadow-hard-lg transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-hard"
          >
            Back home
          </a>
        </div>
      </>
    )}
  </section>
</StorefrontLayout>
