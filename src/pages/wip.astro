---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PLUGGED / 3</title>
    <meta
      name="description"
      content="Plugged Audio route three, a table-top zine catalog for entry IEMs."
    />
  </head>
  <body>
    <main class="table" data-table>
      <canvas id="table-cable" aria-hidden="true"></canvas>
      <div class="dust" aria-hidden="true"></div>

      <div class="desk" aria-hidden="true">
        <span class="tape tape-a"></span>
        <span class="tape tape-b"></span>
        <span class="tape tape-c"></span>
        <span class="coffee"></span>
        <span class="knife-line"></span>
        <span class="scribble scribble-a">seal first</span>
        <span class="scribble scribble-b">no rankings</span>
        <span class="scribble scribble-c">listen, then decide</span>
      </div>

      <header class="rail">
        <a href="/" aria-label="Plugged home" class="rail-logo">
          <img src="/logo.png" alt="" />
        </a>
        <p>PLUGGED AUDIO / ENTRY IEM CATALOG / ISSUE 003</p>
      </header>

      <section class="cover" aria-labelledby="title">
        <div class="cover-mark">
          <img src="/logo.png" alt="" />
        </div>
        <div class="title-sheet">
          <p>photocopied stock table</p>
          <h1 id="title" data-copy="PLUGGED">PLUGGED</h1>
          <span>Better sound without the forum ritual.</span>
        </div>
      </section>

      <section class="catalog" aria-label="Product catalog">
        <div class="spine">
          <span>start here</span>
          <strong>4</strong>
          <span>sets</span>
        </div>
        {
          products.map((product, index) => (
            <article class={`specimen specimen-${index + 1}`}>
              <button type="button" class="specimen-hit" data-product>
                <span class="pin"></span>
                <img src={product.image} alt={`${product.full} product photo`} />
                <span class="caption">
                  <small>{product.note}</small>
                  <strong>{product.name}</strong>
                  <em>{product.price}</em>
                </span>
              </button>
            </article>
          ))
        }
      </section>

      <aside class="decision" aria-label="Buying notes">
        <p>Fit decides bass.</p>
        <p>Tip size changes everything.</p>
        <p>Spend less first. Learn what you like.</p>
      </aside>

      <footer class="seal">
        <img src="/logo.png" alt="" />
        <p>PLUGGED AUDIO SUPPLY</p>
      </footer>
    </main>

    <script is:inline type="module">
      import * as THREE from "https://esm.sh/three@0.167.1";

      const canvas = document.querySelector("#table-cable");
      const table = document.querySelector("[data-table]");
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      const pointer = new THREE.Vector2();
      const group = new THREE.Group();
      scene.add(group);
      camera.position.set(0, 0.2, 16);

      const ink = new THREE.MeshStandardMaterial({ color: "#161513", roughness: 0.64, metalness: 0.24 });
      const orange = new THREE.MeshStandardMaterial({ color: "#ea580c", roughness: 0.52, metalness: 0.18 });
      const paper = new THREE.MeshStandardMaterial({ color: "#e8dfbf", roughness: 0.74, metalness: 0.2 });
      const rubber = new THREE.MeshStandardMaterial({ color: "#24211c", roughness: 0.95 });

      function iemShape() {
        const shape = new THREE.Shape();
        shape.moveTo(-0.92, 0.08);
        shape.bezierCurveTo(-0.78, 0.78, -0.2, 1.02, 0.42, 0.88);
        shape.bezierCurveTo(1.08, 0.72, 1.2, 0.12, 0.94, -0.3);
        shape.bezierCurveTo(0.68, -0.76, 0.12, -0.94, -0.34, -0.84);
        shape.bezierCurveTo(-0.82, -0.74, -1.08, -0.38, -0.98, -0.06);
        shape.bezierCurveTo(-0.96, 0.01, -0.94, 0.05, -0.92, 0.08);
        return shape;
      }

      function shell(side) {
        const g = new THREE.Group();
        const body = new THREE.Mesh(new THREE.ExtrudeGeometry(iemShape(), {
          depth: 0.42,
          bevelEnabled: true,
          bevelSize: 0.08,
          bevelThickness: 0.08,
          bevelSegments: 8,
        }), ink);
        body.scale.x = side;
        body.position.z = -0.28;
        const plate = new THREE.Mesh(new THREE.ExtrudeGeometry(iemShape(), {
          depth: 0.08,
          bevelEnabled: true,
          bevelSize: 0.035,
          bevelThickness: 0.035,
          bevelSegments: 5,
        }), orange);
        plate.scale.set(side * 0.8, 0.8, 1);
        plate.position.z = 0.16;
        const nozzle = new THREE.Mesh(new THREE.CylinderGeometry(0.16, 0.24, 0.82, 24), ink);
        nozzle.position.set(side * 0.92, -0.34, -0.08);
        nozzle.rotation.set(0.08, side * 0.28, Math.PI / 2 + side * 0.14);
        const tip = new THREE.Mesh(new THREE.CylinderGeometry(0.28, 0.42, 0.46, 28), rubber);
        tip.position.set(side * 1.46, -0.48, -0.14);
        tip.rotation.set(0.08, side * 0.28, Math.PI / 2 + side * 0.14);
        const relief = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.1, 0.55, 14), paper);
        relief.position.set(side * -0.88, 0.88, 0.08);
        relief.rotation.set(Math.PI / 2, 0, side * 0.8);
        g.add(body, plate, nozzle, tip, relief);
        g.rotation.set(0.16, side * 0.28, side * -0.34);
        return g;
      }

      const left = shell(-1);
      left.position.set(-1.65, 0.22, 0);
      const right = shell(1);
      right.position.set(1.45, -0.3, -0.18);
      right.rotation.z = 0.5;
      group.add(left, right);

      const curve = new THREE.CatmullRomCurve3([
        new THREE.Vector3(-2.55, 1.12, 0.05),
        new THREE.Vector3(-5.2, 2.5, -1.2),
        new THREE.Vector3(-2.5, 4.2, -2),
        new THREE.Vector3(1.1, 3.35, -1.4),
        new THREE.Vector3(5.2, 2.1, -1.2),
        new THREE.Vector3(2.34, 0.44, -0.08),
      ]);
      group.add(new THREE.Mesh(new THREE.TubeGeometry(curve, 180, 0.035, 8), paper));

      group.position.set(2.5, -0.8, 0);
      group.scale.set(1.25, 1.25, 1.25);
      scene.add(new THREE.AmbientLight("#f2ecd8", 0.74));
      const key = new THREE.DirectionalLight("#f2ecd8", 2.3);
      key.position.set(5, 6, 7);
      scene.add(key);
      const hot = new THREE.PointLight("#ea580c", 16, 20);
      hot.position.set(-4, -1, 5);
      scene.add(hot);

      function size() {
        const width = window.innerWidth;
        const height = window.innerHeight;
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.7));
        renderer.setSize(width, height, false);
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
      }

      function frame(ms) {
        const t = ms * 0.001;
        group.rotation.x = Math.sin(t * 0.3) * 0.1 + pointer.y * 0.08;
        group.rotation.y = Math.sin(t * 0.22) * 0.18 + pointer.x * 0.22;
        group.rotation.z = Math.sin(t * 0.25) * 0.06;
        renderer.render(scene, camera);
        requestAnimationFrame(frame);
      }

      window.addEventListener("resize", size);
      window.addEventListener("pointermove", (event) => {
        pointer.x = (event.clientX / window.innerWidth - 0.5) * 2;
        pointer.y = -(event.clientY / window.innerHeight - 0.5) * 2;
        table.style.setProperty("--mx", `${event.clientX}px`);
        table.style.setProperty("--my", `${event.clientY}px`);
      }, { passive: true });

      document.querySelectorAll("[data-product]").forEach((button) => {
        button.addEventListener("pointermove", (event) => {
          const rect = button.getBoundingClientRect();
          button.style.setProperty("--hx", `${event.clientX - rect.left}px`);
          button.style.setProperty("--hy", `${event.clientY - rect.top}px`);
        });
      });

      size();
      requestAnimationFrame(frame);
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --news: oklch(94% 0.02 92);
    --paper: oklch(90% 0.025 95);
    --edge: oklch(82% 0.02 95);
    --ink: oklch(15% 0.01 85);
    --muted: oklch(42% 0.01 85);
    --orange: oklch(64% 0.26 55);
    --yellow: oklch(88% 0.18 98);
    --cyan: oklch(65% 0.18 230);
    font-family: "Arial Narrow", Impact, "Helvetica Neue", Arial, system-ui, sans-serif;
    background: var(--news);
  }

  * { box-sizing: border-box; }
  html { background: var(--news); }
  body {
    min-width: 320px;
    margin: 0;
    overflow-x: hidden;
    background: var(--news);
    color: var(--ink);
  }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; }

  .table {
    --mx: 50vw;
    --my: 50vh;
    position: relative;
    min-height: 210svh;
    isolation: isolate;
    background:
      radial-gradient(circle at var(--mx) var(--my), oklch(64% 0.26 55 / 0.18), transparent 22rem),
      repeating-linear-gradient(90deg, oklch(15% 0.01 85 / 0.035) 0 1px, transparent 1px 2.2rem),
      var(--news);
  }

  #table-cable {
    position: fixed;
    inset: 0;
    z-index: 1;
    width: 100vw;
    height: 100svh;
    opacity: 0.36;
    mix-blend-mode: multiply;
  }

  .dust,
  .dust::before,
  .dust::after {
    position: fixed;
    inset: 0;
    z-index: 80;
    pointer-events: none;
    content: "";
  }
  .dust {
    opacity: 0.3;
    mix-blend-mode: multiply;
    background-image:
      repeating-radial-gradient(circle at 22% 18%, oklch(15% 0.01 85 / 0.18) 0 1px, transparent 1px 4px),
      repeating-linear-gradient(0deg, transparent 0 5px, oklch(15% 0.01 85 / 0.08) 5px 6px);
    animation: dirt 0.5s steps(2) infinite;
  }
  .dust::after {
    opacity: 0.22;
    background: radial-gradient(circle at center, transparent 0 48%, oklch(15% 0.01 85 / 0.35) 100%);
  }

  .desk {
    position: fixed;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .tape,
  .scribble,
  .coffee,
  .knife-line {
    position: absolute;
    display: block;
  }
  .tape {
    width: clamp(12rem, 20vw, 24rem);
    height: 1.4rem;
    background: oklch(90% 0.025 95 / 0.72);
    clip-path: polygon(2% 0, 100% 12%, 94% 100%, 0 88%);
    box-shadow: 0.3rem 0.35rem 0 oklch(15% 0.01 85 / 0.16);
  }
  .tape-a { left: 7vw; top: 16svh; transform: rotate(-8deg); }
  .tape-b { right: 9vw; top: 13svh; transform: rotate(5deg); background: oklch(88% 0.18 98 / 0.65); }
  .tape-c { left: 43vw; bottom: 12svh; transform: rotate(-3deg); }
  .scribble {
    font-family: "Comic Sans MS", "Bradley Hand", cursive;
    color: oklch(15% 0.01 85 / 0.42);
    font-size: clamp(1.3rem, 3vw, 3.5rem);
    font-weight: 900;
    line-height: 0.85;
  }
  .scribble-a { left: 9vw; bottom: 23svh; transform: rotate(-9deg); }
  .scribble-b { right: 13vw; bottom: 31svh; transform: rotate(8deg); color: oklch(64% 0.26 55 / 0.55); }
  .scribble-c { left: 42vw; top: 45svh; transform: rotate(4deg); color: oklch(65% 0.18 230 / 0.55); }
  .coffee {
    right: 3vw;
    top: 36svh;
    width: 13rem;
    aspect-ratio: 1;
    border: 1.3rem solid oklch(42% 0.05 55 / 0.16);
    border-radius: 50%;
    transform: rotate(13deg);
  }
  .knife-line {
    left: 18vw;
    top: 63svh;
    width: 54vw;
    height: 1px;
    background: oklch(15% 0.01 85 / 0.22);
    transform: rotate(-7deg);
  }

  .rail {
    position: fixed;
    left: 1rem;
    top: 1rem;
    right: 1rem;
    z-index: 90;
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--ink);
    mix-blend-mode: multiply;
  }
  .rail-logo img {
    width: 3.4rem;
    aspect-ratio: 1;
    object-fit: cover;
    clip-path: polygon(4% 0, 100% 8%, 91% 100%, 0 93%);
  }
  .rail p {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
  }

  .cover {
    position: relative;
    z-index: 10;
    min-height: 100svh;
    padding: 7rem clamp(1rem, 5vw, 5rem) 3rem;
  }
  .cover-mark {
    position: absolute;
    right: clamp(1rem, 6vw, 6rem);
    top: 13svh;
    width: clamp(12rem, 26vw, 28rem);
    background: var(--paper);
    padding: 0.8rem;
    clip-path: polygon(5% 0, 100% 7%, 91% 100%, 0 93%);
    box-shadow: 0.9rem 1rem 0 oklch(15% 0.01 85 / 0.24);
    transform: rotate(8deg);
  }
  .cover-mark img {
    width: 100%;
    display: block;
    mix-blend-mode: multiply;
  }
  .title-sheet {
    position: sticky;
    top: 6rem;
    width: min(76rem, 100%);
    padding: clamp(1rem, 2.5vw, 2rem);
    background:
      linear-gradient(180deg, oklch(94% 0.02 92 / 0.96), oklch(90% 0.025 95 / 0.76)),
      repeating-linear-gradient(0deg, transparent 0 8px, oklch(15% 0.01 85 / 0.08) 8px 9px);
    clip-path: polygon(1% 1%, 100% 4%, 96% 100%, 0 93%);
    box-shadow: 1rem 1rem 0 oklch(15% 0.01 85 / 0.22);
    transform: rotate(-1.5deg);
  }
  .title-sheet p {
    margin: 0 0 0.6rem;
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  h1 {
    position: relative;
    width: min-content;
    margin: 0;
    color: var(--ink);
    font-size: clamp(5rem, 17vw, 17rem);
    font-weight: 900;
    line-height: 0.76;
    text-transform: uppercase;
    text-shadow:
      0.035em 0.035em 0 var(--orange),
      -0.025em 0.055em 0 oklch(65% 0.18 230 / 0.72);
  }
  h1::before,
  h1::after {
    position: absolute;
    inset: 0;
    content: attr(data-copy);
    pointer-events: none;
  }
  h1::before {
    color: var(--orange);
    clip-path: inset(54% 0 12% 0);
    transform: translate(0.045em, 0.018em);
    mix-blend-mode: multiply;
  }
  h1::after {
    color: oklch(65% 0.18 230 / 0.7);
    clip-path: inset(6% 0 72% 0);
    transform: translate(-0.035em, -0.01em);
    mix-blend-mode: multiply;
  }
  .title-sheet span {
    display: block;
    max-width: 36rem;
    margin-top: 1rem;
    font-family: Arial, "Helvetica Neue", system-ui, sans-serif;
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    font-weight: 700;
    line-height: 1.45;
  }

  .catalog {
    position: relative;
    z-index: 12;
    min-height: 92svh;
    padding: 3rem clamp(1rem, 5vw, 5rem) 10rem;
  }
  .spine {
    position: absolute;
    left: clamp(1rem, 5vw, 5rem);
    top: 4rem;
    display: grid;
    justify-items: center;
    width: 6.2rem;
    padding: 0.8rem;
    background: var(--orange);
    color: var(--ink);
    clip-path: polygon(5% 0, 100% 7%, 91% 100%, 0 93%);
    box-shadow: 0.45rem 0.5rem 0 var(--ink);
    transform: rotate(-4deg);
    text-transform: uppercase;
  }
  .spine strong {
    font-size: 5rem;
    line-height: 0.85;
  }
  .spine span {
    font-size: 0.8rem;
    font-weight: 900;
  }
  .specimen {
    position: absolute;
    width: clamp(15rem, 25vw, 25rem);
  }
  .specimen-1 { left: 14vw; top: 4rem; transform: rotate(-5deg); }
  .specimen-2 { left: 43vw; top: 0; transform: rotate(3deg); }
  .specimen-3 { right: 4vw; top: 12rem; transform: rotate(-2deg); }
  .specimen-4 { left: 28vw; top: 34rem; transform: rotate(4deg); }
  .specimen-hit {
    --hx: 50%;
    --hy: 35%;
    position: relative;
    display: grid;
    width: 100%;
    min-height: clamp(25rem, 38vw, 36rem);
    overflow: hidden;
    border: 2px solid var(--ink);
    background:
      radial-gradient(circle at var(--hx) var(--hy), oklch(88% 0.18 98 / 0.65), transparent 10rem),
      linear-gradient(180deg, var(--paper), var(--edge));
    color: var(--ink);
    cursor: pointer;
    text-align: left;
    clip-path: polygon(2% 0, 100% 5%, 96% 100%, 0 94%);
    box-shadow: 0.7rem 0.8rem 0 oklch(15% 0.01 85 / 0.28);
  }
  .pin {
    position: absolute;
    left: 50%;
    top: 0.9rem;
    z-index: 4;
    width: 38%;
    height: 1.15rem;
    background: oklch(94% 0.02 92 / 0.7);
    transform: translateX(-50%) rotate(-3deg);
  }
  .specimen-hit img {
    align-self: start;
    justify-self: center;
    width: 92%;
    max-height: 57%;
    margin-top: 2.8rem;
    object-fit: contain;
    filter: grayscale(0.9) contrast(1.25) drop-shadow(0.35rem 0.45rem 0 oklch(15% 0.01 85 / 0.28));
    transition: filter 160ms ease, transform 160ms ease;
  }
  .specimen-hit:hover img,
  .specimen-hit:focus-visible img {
    filter: grayscale(0.1) contrast(1.12) saturate(1.05) drop-shadow(0.42rem 0.52rem 0 oklch(15% 0.01 85 / 0.35));
    transform: scale(1.06) rotate(-2deg);
  }
  .caption {
    align-self: end;
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    text-transform: uppercase;
  }
  .caption small,
  .caption em {
    color: var(--orange);
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 900;
  }
  .caption strong {
    color: var(--ink);
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 900;
    line-height: 0.84;
  }

  .decision {
    position: relative;
    z-index: 11;
    display: grid;
    gap: 0.7rem;
    width: min(36rem, calc(100% - 2rem));
    margin: 0 clamp(1rem, 5vw, 5rem) 10rem auto;
    transform: rotate(2deg);
  }
  .decision p {
    margin: 0;
    padding: 0.75rem 0.9rem;
    background: var(--yellow);
    color: var(--ink);
    font-family: "Comic Sans MS", "Bradley Hand", cursive;
    font-size: clamp(1.15rem, 2.2vw, 2.2rem);
    font-weight: 900;
    line-height: 0.9;
    clip-path: polygon(2% 0, 100% 8%, 96% 100%, 0 90%);
    box-shadow: 0.35rem 0.42rem 0 oklch(15% 0.01 85 / 0.28);
  }
  .decision p:nth-child(2) { background: var(--paper); transform: rotate(-2deg); }
  .decision p:nth-child(3) { background: oklch(65% 0.18 230 / 0.68); }

  .seal {
    position: relative;
    z-index: 12;
    display: flex;
    align-items: end;
    gap: clamp(1rem, 4vw, 4rem);
    min-height: 40svh;
    padding: 4rem clamp(1rem, 5vw, 5rem);
    background: var(--paper);
    clip-path: polygon(0 8%, 100% 0, 100% 100%, 0 100%);
  }
  .seal img {
    width: min(13rem, 42vw);
    background: var(--news);
    clip-path: polygon(5% 0, 100% 7%, 91% 100%, 0 94%);
    box-shadow: 0.55rem 0.6rem 0 oklch(15% 0.01 85 / 0.28);
    mix-blend-mode: multiply;
    transform: rotate(-5deg);
  }
  .seal p {
    margin: 0;
    color: var(--ink);
    font-size: clamp(2rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 0.82;
  }

  @keyframes dirt {
    to { transform: translate(-2%, 1%); }
  }

  @media (max-width: 900px) {
    .table { min-height: auto; }
    .cover {
      min-height: auto;
      padding-top: 6rem;
    }
    .cover-mark {
      position: relative;
      inset: auto;
      width: min(17rem, 72vw);
      margin: 2rem 0 0 auto;
    }
    h1 { font-size: clamp(4.2rem, 21vw, 8rem); }
    .catalog {
      display: grid;
      gap: 1.2rem;
      min-height: auto;
      padding-bottom: 4rem;
    }
    .spine,
    .specimen,
    .specimen-1,
    .specimen-2,
    .specimen-3,
    .specimen-4 {
      position: relative;
      inset: auto;
      width: 100%;
      transform: rotate(-1deg);
    }
    .spine {
      width: 8rem;
    }
