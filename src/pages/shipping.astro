---
/**
 * Shipping info — flat 6000 MNT fee, delivery times, coverage areas.
 * Prerendered. Placeholder content.
 */
import StorefrontLayout from "../layouts/StorefrontLayout.astro";
import InfoPageHeader from "../components/storefront/InfoPageHeader.astro";
import { formatMnt } from "../lib/utils";

export const prerender = true;

const SHIPPING_FEE_MNT = 6000;
const FREE_SHIPPING_THRESHOLD_MNT = 150000;

const zones = [
  {
    name: "Ulaanbaatar",
    fee: formatMnt(SHIPPING_FEE_MNT),
    eta: "1–3 business days",
    note: "Courier hand-delivery or pickup at the nearest depot. COD available.",
  },
  {
    name: "Provincial capitals",
    fee: formatMnt(SHIPPING_FEE_MNT),
    eta: "3–5 business days",
    note: "Delivered to the aimag center. Pickup from the local post office if outside the center.",
  },
  {
    name: "Rural / soums",
    fee: formatMnt(SHIPPING_FEE_MNT),
    eta: "5–7 business days",
    note: "Routed via the national post network. Address must include the soum and bagh.",
  },
];

const notes = [
  "Orders placed before 14:00 ship same day. After that, next business day.",
  `Free shipping kicks in on orders over ${formatMnt(FREE_SHIPPING_THRESHOLD_MNT)} — automatically applied at checkout.`,
  "We don't ship on weekends or public holidays. Plan accordingly.",
  "Tracking links are emailed the moment the parcel leaves the warehouse.",
  "Lost or damaged in transit? We reship at our cost — just send the tracking number.",
];
---

<StorefrontLayout
  title="Shipping | Plugged"
  description={`Flat ${formatMnt(SHIPPING_FEE_MNT)} delivery anywhere in Mongolia. Delivery times and coverage areas.`}
>
  <InfoPageHeader
    kicker="Logistics / dispatch"
    title="Shipping"
    tagline={`Flat ${formatMnt(SHIPPING_FEE_MNT)}. Everywhere.`}
  />

  <section class="mx-auto max-w-screen-2xl px-4 py-14 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      {/* Fee callout — stamped */}
      <div
        class="mb-10 inline-flex -rotate-1 flex-col gap-1 border-4 border-ink bg-yellow p-5 shadow-hard-lg"
      >
        <span class="text-micro font-black uppercase tracking-widest text-ink">
          Flat rate
        </span>
        <span class="font-display text-4xl font-black uppercase tracking-tight text-ink lg:text-5xl">
          {formatMnt(SHIPPING_FEE_MNT)}
        </span>
        <span class="text-body font-bold text-ink-muted">
          Anywhere in Mongolia · free over {formatMnt(FREE_SHIPPING_THRESHOLD_MNT)}
        </span>
      </div>

      {/* Coverage zones — zine cards */}
      <h2 class="mb-5 font-display text-heading-lg font-black uppercase tracking-tight text-ink">
        Coverage &amp; times
      </h2>
      <div class="grid gap-4 md:grid-cols-3">
        {
          zones.map((zone, i) => (
            <div
              class="relative border-4 border-ink bg-card p-5 shadow-hard transition-all hover:border-orange"
              style={`transform: rotate(${i % 2 === 0 ? "0.6deg" : "-0.6deg"});`}
            >
              <span
                class="absolute -top-3 -right-3 inline-flex items-center border-2 border-ink bg-orange px-2 py-0.5 text-micro font-black uppercase tracking-widest text-ink shadow-hard-sm"
                style="transform: rotate(4deg);"
              >
                {zone.fee}
              </span>
              <h3 class="font-display text-heading-lg font-black uppercase tracking-tight text-ink">
                {zone.name}
              </h3>
              <p class="mt-1 text-body font-bold text-ink">
                {zone.eta}
              </p>
              <p class="mt-2 text-body font-medium leading-relaxed text-ink-muted">
                {zone.note}
              </p>
            </div>
          ))
        }
      </div>

      {/* Notes — taped list */}
      <h2 class="mb-5 mt-12 font-display text-heading-lg font-black uppercase tracking-tight text-ink">
        The fine print
      </h2>
      <ul class="flex flex-col gap-3">
        {
          notes.map((note) => (
            <li class="flex items-start gap-3 border-l-4 border-ink bg-newsprint-2 bg-noise px-4 py-3">
              <span
                class="mt-1 inline-block size-2 shrink-0 bg-orange"
                aria-hidden="true"
              >
              </span>
              <span class="text-body font-medium leading-relaxed text-ink">
                {note}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</StorefrontLayout>
