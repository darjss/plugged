---
import StorefrontLayout from "../layouts/StorefrontLayout.astro";
import OrderTracking from "../components/storefront/OrderTracking.tsx";

export const prerender = false;

// Optional deep-link prefill: `/track?phone=88889999` (8 digits, no +976).
// Used by the profile page order links.
const initialPhone = Astro.url.searchParams.get("phone") ?? undefined;
---

<StorefrontLayout
  title="Track Order | Plugged"
  description="Enter your phone number to check the status, address, and payment of your order."
>
  <section class="mx-auto max-w-2xl px-4 py-12 md:py-16">
    {/* Header — stamp-style */}
    <div class="mb-8">
      <div class="inline-block -rotate-1 border-2 border-ink bg-orange px-4 py-2 shadow-hard-sm">
        <h1 class="font-display text-4xl uppercase leading-none text-ink md:text-5xl">
          Track order
        </h1>
      </div>
      <p class="mt-3 max-w-md font-mono text-xs uppercase tracking-wider text-ink-muted">
        Enter the phone number you used at checkout to see your order status, address, and payment info. No sign-in required.
      </p>
    </div>

    <OrderTracking client:only="solid-js" initialPhone={initialPhone} />
  </section>
</StorefrontLayout>
