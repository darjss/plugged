---
/**
 * Plugged homepage — hero + featured products + category nav + edu teaser.
 * SSR (prerender = false) so featured products stay fresh against D1.
 * Pulls real data from commerceQueries — same module the /products API uses.
 */
import StorefrontLayout from "../layouts/StorefrontLayout.astro";
import Hero from "../components/storefront/Hero.astro";
import FeaturedProducts from "../components/storefront/FeaturedProducts.astro";
import CategoryNav from "../components/storefront/CategoryNav.astro";
import WhyIems from "../components/storefront/WhyIems.astro";
import { commerceQueries } from "../server/commerce/queries";

export const prerender = false;

let featuredProducts: Awaited<ReturnType<typeof commerceQueries.store.getProducts>> = [];
try {
  featuredProducts = await commerceQueries.store.getProducts({ featured: true });
} catch (error) {
  console.error("[homepage] failed to load featured products", { error: String(error) });
}
---

<StorefrontLayout
  title="Plugged — Premium IEMs. No BS."
  description="In-ear monitors, DAC amps, and wireless earbuds. Photocopied signal, warehouse-rave prices."
>
  <Hero />
  <FeaturedProducts products={featuredProducts} />
  <CategoryNav />
  <WhyIems />
</StorefrontLayout>
