---
const products = [
  {
    name: "MOONDROP CHU II",
    price: "$19",
    tag: "metal shell starter",
    color: "var(--rust)",
    image:
      "https://cn.cdn.moondroplab.com/627128d862c9a44234848dda/64a67decb6354a3471c0d4cd_CHU2.jpg",
  },
  {
    name: "7Hz Zero:2",
    price: "$24",
    tag: "crinacle street pick",
    color: "var(--clay)",
    image:
      "https://www.theaudiostore.in/cdn/shop/files/7hz-x-crinacle-zero-2-iem-with-mic-orange-44271691333887.webp?v=1744393797&width=900",
  },
  {
    name: "Kiwi Ears Belle",
    price: "$30",
    tag: "black plate daily",
    color: "var(--ash)",
    image:
      "https://kiwiears.com/cdn/shop/files/KiwiEarsBelle_2_08949fc3-017c-4815-a6cb-8caa6ad6a52f.jpg?v=1773412066&width=1200",
  },
  {
    name: "TRUTHEAR Zero:Red",
    price: "$55",
    tag: "red shell pressure",
    color: "var(--blood)",
    image:
      "https://prom.ua/img/2458303318_w640_h640_vnutrikanalnye-iem-naushniki.jpg",
  },
];

const drops = [
  "bass with concrete dust on it",
  "vocals folded into a ripped black hoodie",
  "pocket gear for the friend who vanishes at 3:11",
  "for walking home with your fit still smoking",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Plugged is a grunge rave ecommerce concept for IEMs, cables, tips, and listening gear."
    />
    <title>Plugged | Grit Audio Store</title>
  </head>
  <body>
    <svg class="filter-bank" aria-hidden="true">
      <filter id="noise">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.85"
          numOctaves="3"
          seed="19"
        />
        <feDisplacementMap in="SourceGraphic" scale="7" />
      </filter>
    </svg>

    <main class="shop-stage" data-stage>
      <div class="grain" aria-hidden="true"></div>
      <div class="scan" aria-hidden="true"></div>
      <div class="paste-wall" aria-hidden="true">
        <span>AUTHORIZED LOITERING</span>
        <span>PLUG IN OR LEAVE</span>
        <span>NO WINDOW SHOPPING AFTER MIDNIGHT</span>
        <span>BOOTLEG FEEL / REAL STOCK</span>
      </div>

      <header class="site-head" aria-label="Primary">
        <a class="mark" href="/">
          <span>PLUGGED</span>
          <small>private audio supply</small>
        </a>
        <nav>
          <a href="#drop">drop</a>
          <a href="#tunnel">tunnel</a>
          <a href="#cart">cart</a>
        </nav>
        <button class="bag" type="button" data-cart-button aria-label="Open bag">
          <span data-count>0</span>
        </button>
      </header>

      <section class="hero" id="drop" aria-labelledby="home-title">
        <div class="hero-copy">
          <p class="kicker">02:47 AM / no receipt no problem</p>
          <h1 id="home-title" data-glitch="PLUGGED">PLUGGED</h1>
          <p class="manifesto">
            Pocket audio for kids who dress like the venue lost power and still
            know exactly where the bass is buried.
          </p>
          <div class="hero-actions" aria-label="Shopping actions">
            <a href="#wall">raid the wall</a>
            <a href="#cart">stash a kit</a>
          </div>
        </div>

        <div class="signal-orbit" aria-hidden="true">
          <span style="--i:0"></span>
          <span style="--i:1"></span>
          <span style="--i:2"></span>
          <span style="--i:3"></span>
          <span style="--i:4"></span>
          <span style="--i:5"></span>
        </div>

        <div class="hero-product" aria-label="Featured product">
          <div class="iem-object">
            <div class="shell shell-left"></div>
            <div class="shell shell-right"></div>
            <div class="cable"></div>
          </div>
          <span class="hero-photo">
            <img src={products[0].image} alt="MOONDROP CHU II in-ear monitors" />
          </span>
          <p>MOONDROP CHU II</p>
          <strong>$19 / floor model energy</strong>
        </div>
      </section>

      <section class="ticker" aria-label="Store mood">
        <div>
          <span>DIRTY FIT CLEAN SIGNAL</span>
          <span>POCKET HI-FI</span>
          <span>BLACK FOAM / NO SMALL TALK</span>
          <span>STOCK DROPS WHEN THE LIGHTS CUT</span>
          <span>DIRTY FIT CLEAN SIGNAL</span>
          <span>POCKET HI-FI</span>
        </div>
      </section>

      <section class="product-wall" id="wall" aria-labelledby="wall-title">
        <div class="wall-intro">
          <p class="kicker">shop like you found it taped to a pole</p>
          <h2 id="wall-title">If it looks stolen, it probably sounds expensive.</h2>
        </div>

        <div class="wall-grid">
          {
            products.map((product, index) => (
              <article
                class="product-slab"
                style={`--accent:${product.color}; --delay:${index * 90}ms`}
              >
                <button
                  type="button"
                  class="buy-zone"
                  data-add
                  data-product={product.name}
                  aria-label={`Add ${product.name} to cart`}
                >
                  <span class="product-visual" aria-hidden="true">
                    <img
                      src={product.image}
                      alt={`${product.name} in-ear monitor product photo`}
                      loading={index === 0 ? "eager" : "lazy"}
                    />
                  </span>
                  <span class="product-meta">
                    <small>{product.tag}</small>
                    <strong>{product.name}</strong>
                    <em>{product.price}</em>
                  </span>
                  <span class="add-flash">add</span>
                </button>
              </article>
            ))
          }
        </div>
      </section>

      <section class="tunnel" id="tunnel" aria-labelledby="tunnel-title">
        <div class="tunnel-copy">
          <p class="kicker">underpass listening test</p>
          <h2 id="tunnel-title">The drop is quiet until it owns you.</h2>
        </div>
        <div class="tunnel-rails" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <ol class="drop-list">
          {drops.map((drop) => <li>{drop}</li>)}
        </ol>
      </section>

      <section class="cart-lab" id="cart" aria-labelledby="cart-title">
        <div>
          <p class="kicker">checkout for the unavailable</p>
          <h2 id="cart-title">Make your pockets heavier.</h2>
          <p>
            Start with the shells, grab the cable, seal the city out, and act
            like you did not spend rent money on tiny speakers.
          </p>
        </div>
        <div class="receipt" data-receipt>
          <span>empty bag</span>
          <strong>$0</strong>
          <button type="button" data-add-random>grab blind</button>
        </div>
      </section>
    </main>

    <script>
      const stage = document.querySelector("[data-stage]");
      const count = document.querySelector("[data-count]");
      const receipt = document.querySelector("[data-receipt]");
      const addButtons = document.querySelectorAll("[data-add]");
      const randomButton = document.querySelector("[data-add-random]");
      const products = [
        ["MOONDROP CHU II", 19],
        ["7Hz Zero:2", 24],
        ["Kiwi Ears Belle", 30],
        ["TRUTHEAR Zero:Red", 55],
      ];
      let cart = [];

      function renderCart() {
        const total = cart.reduce((sum, item) => sum + item[1], 0);
        count.textContent = String(cart.length);
        receipt.innerHTML = `
          <span>${cart.length ? cart.map((item) => item[0]).join(" / ") : "empty bag"}</span>
          <strong>$${total}</strong>
          <button type="button" data-add-random>grab blind</button>
        `;
        receipt.querySelector("[data-add-random]").addEventListener("click", addRandom);
        stage.classList.remove("cart-hit");
        requestAnimationFrame(() => stage.classList.add("cart-hit"));
      }

      function addItem(name) {
        const item = products.find((product) => product[0] === name);
        if (!item) return;
        cart = [...cart, item];
        renderCart();
      }

      function addRandom() {
        addItem(products[Math.floor(Math.random() * products.length)][0]);
      }

      addButtons.forEach((button) => {
        button.addEventListener("click", () => addItem(button.dataset.product));
      });
      randomButton.addEventListener("click", addRandom);

      window.addEventListener(
        "pointermove",
        (event) => {
          stage.style.setProperty("--mx", `${(event.clientX / window.innerWidth) * 100}%`);
          stage.style.setProperty("--my", `${(event.clientY / window.innerHeight) * 100}%`);
        },
        { passive: true },
      );
    </script>
  </body>
</html>

<style>
  :root {
    --ink: #050505;
    --tar: #0c0b09;
    --soot: #171512;
    --paper: #e1d8c2;
    --bone: #b8ad93;
    --rust: #8f3424;
    --clay: #7b6250;
    --ash: #6f7067;
    --blood: #7f1d18;
    --smoke: rgba(225, 216, 194, 0.72);
    color-scheme: dark;
    font-family:
      "Arial Narrow", "Helvetica Neue", Arial, system-ui, sans-serif;
    background: var(--ink);
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--ink);
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    margin: 0;
    overflow-x: hidden;
    background: var(--ink);
    color: var(--paper);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    font: inherit;
  }

  .filter-bank {
    position: absolute;
    width: 0;
    height: 0;
  }

  .shop-stage {
    --mx: 55%;
    --my: 32%;
    position: relative;
    min-height: 100svh;
    isolation: isolate;
    background:
      radial-gradient(circle at var(--mx) var(--my), rgba(143, 52, 36, 0.22), transparent 24rem),
      radial-gradient(circle at 82% 8%, rgba(184, 173, 147, 0.13), transparent 20rem),
      repeating-linear-gradient(101deg, rgba(255,255,255,0.025) 0 1px, transparent 1px 11px),
      linear-gradient(105deg, #050505 0%, #15130f 49%, #070605 100%);
  }

  .shop-stage::before,
  .shop-stage::after {
    position: fixed;
    inset: 0;
    pointer-events: none;
    content: "";
  }

  .shop-stage::before {
    z-index: 1;
    opacity: 0.32;
    background:
      linear-gradient(90deg, transparent 0 9%, rgba(225, 216, 194, 0.05) 9% 10%, transparent 10% 22%),
      repeating-linear-gradient(176deg, transparent 0 19px, rgba(225, 216, 194, 0.04) 19px 20px),
      radial-gradient(circle at 20% 42%, rgba(127, 29, 24, 0.18), transparent 13rem);
    mix-blend-mode: hard-light;
  }

  .shop-stage::after {
    z-index: 19;
    opacity: 0.26;
    background-image:
      linear-gradient(18deg, transparent 0 44%, rgba(225, 216, 194, 0.09) 44% 45%, transparent 45%),
      repeating-linear-gradient(88deg, transparent 0 3rem, rgba(0,0,0,0.64) 3rem 3.1rem);
    mix-blend-mode: multiply;
  }

  .grain,
  .scan {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 20;
  }

  .grain {
    opacity: 0.48;
    mix-blend-mode: soft-light;
    background-image:
      repeating-radial-gradient(circle at 17% 21%, rgba(255,255,255,0.18) 0 1px, transparent 1px 4px),
      repeating-radial-gradient(circle at 73% 63%, rgba(0,0,0,0.8) 0 1px, transparent 1px 6px),
      repeating-linear-gradient(93deg, transparent 0 2px, rgba(255,255,255,0.08) 2px 3px);
    animation: grain-shift 0.7s steps(2) infinite;
  }

  .scan {
    opacity: 0.11;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0 5px,
      rgba(225, 216, 194, 0.22) 5px 6px,
      transparent 6px 12px
    );
  }

  .paste-wall {
    position: fixed;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .paste-wall span {
    position: absolute;
    display: block;
    max-width: 18rem;
    border: 1px solid rgba(225, 216, 194, 0.2);
    background:
      linear-gradient(90deg, rgba(225, 216, 194, 0.9), rgba(184, 173, 147, 0.68)),
      repeating-linear-gradient(0deg, transparent 0 7px, rgba(0,0,0,0.16) 7px 8px);
    color: var(--ink);
    padding: 0.55rem 0.7rem;
    font-size: clamp(0.75rem, 1.8vw, 1.1rem);
    font-weight: 1000;
    line-height: 0.85;
    text-transform: uppercase;
    opacity: 0.15;
    filter: url("#noise");
    box-shadow: 0.3rem 0.35rem 0 rgba(0, 0, 0, 0.55);
  }

  .paste-wall span:nth-child(1) {
    top: 14svh;
    left: 3vw;
    transform: rotate(-9deg);
  }

  .paste-wall span:nth-child(2) {
    top: 31svh;
    right: -1rem;
    transform: rotate(7deg);
  }

  .paste-wall span:nth-child(3) {
    bottom: 19svh;
    left: 9vw;
    transform: rotate(4deg);
  }

  .paste-wall span:nth-child(4) {
    bottom: 8svh;
    right: 13vw;
    transform: rotate(-5deg);
  }

  .site-head {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 30;
    display: grid;
    grid-template-columns: 1fr auto 3rem;
    align-items: center;
    gap: 1rem;
    padding: 1rem clamp(1rem, 3vw, 2.5rem);
    mix-blend-mode: difference;
  }

  .mark {
    display: grid;
    gap: 0.12rem;
    width: max-content;
    font-weight: 950;
    letter-spacing: 0;
    line-height: 0.9;
  }

  .mark span {
    font-size: clamp(1rem, 2vw, 1.55rem);
  }

  .mark small,
  .kicker {
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  nav {
    display: flex;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    font-size: 0.8rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .bag {
    width: 3rem;
    aspect-ratio: 1;
    border: 1px solid currentColor;
    border-radius: 50%;
    background: transparent;
    color: currentColor;
    cursor: pointer;
  }

  .hero {
    position: relative;
    display: grid;
    min-height: 100svh;
    align-items: center;
    overflow: hidden;
    padding: 6rem clamp(1rem, 5vw, 5rem) 4rem;
  }

  .hero::before {
    position: absolute;
    inset: 7rem 4vw 3rem;
    content: "";
    border: 1px solid rgba(244, 240, 223, 0.18);
    transform: rotate(-2deg) skew(-4deg);
    filter: url("#noise");
  }

  .hero-copy {
    position: relative;
    z-index: 3;
    width: min(78rem, 100%);
  }

  .kicker {
    margin: 0 0 1rem;
    color: var(--bone);
  }

  h1 {
    position: relative;
    width: min-content;
    margin: 0;
    font-size: clamp(5rem, 20vw, 16rem);
    font-weight: 1000;
    line-height: 0.72;
    text-transform: uppercase;
    filter: url("#noise");
  }

  h1::before,
  h1::after {
    position: absolute;
    inset: 0;
    content: attr(data-glitch);
    pointer-events: none;
  }

  h1::before {
    color: var(--rust);
    transform: translate(0.055em, -0.025em);
    mix-blend-mode: screen;
    animation: glitch-a 2.4s steps(2) infinite;
  }

  h1::after {
    color: var(--bone);
    transform: translate(-0.045em, 0.03em);
    mix-blend-mode: screen;
    animation: glitch-b 1.9s steps(2) infinite;
  }

  .manifesto {
    width: min(34rem, 100%);
    margin: 1.5rem 0 0;
    font-size: clamp(1.1rem, 2.1vw, 2rem);
    font-weight: 850;
    line-height: 1.05;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .hero-actions a,
  .receipt button {
    border: 1px solid var(--paper);
    background: var(--paper);
    color: var(--ink);
    padding: 0.78rem 1rem;
    font-size: 0.82rem;
    font-weight: 1000;
    text-transform: uppercase;
  }

  .hero-actions a + a {
    background: transparent;
    color: var(--paper);
  }

  .signal-orbit {
    position: absolute;
    inset: 11vh 0 auto 50%;
    width: min(42rem, 78vw);
    aspect-ratio: 1;
    translate: -5% 0;
    opacity: 0.38;
    mix-blend-mode: exclusion;
    animation: float 8s ease-in-out infinite;
  }

  .signal-orbit span {
    position: absolute;
    inset: calc(var(--i) * 7%);
    border: 2px solid color-mix(in oklch, var(--bone), var(--rust) 48%);
    clip-path: polygon(8% 0, 96% 14%, 87% 100%, 0 79%);
    transform: rotate(calc(var(--i) * 17deg));
    animation: ring 5s linear infinite;
    animation-delay: calc(var(--i) * -0.4s);
  }

  .hero-product {
    position: absolute;
    right: clamp(1rem, 5vw, 5rem);
    bottom: clamp(2rem, 6vh, 5rem);
    z-index: 4;
    display: grid;
    gap: 0.35rem;
    width: clamp(16rem, 28vw, 29rem);
    font-weight: 1000;
    text-transform: uppercase;
  }

  .hero-photo {
    position: relative;
    display: grid;
    width: 100%;
    aspect-ratio: 1.08;
    place-items: center;
  }
</style>
