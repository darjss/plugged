---
import StorefrontLayout from "../layouts/StorefrontLayout.astro";
---

<StorefrontLayout title="Demo | Plugged">
  <section class="mx-auto max-w-screen-2xl px-4 py-16 lg:px-8">
    <p class="text-micro font-black uppercase tracking-widest text-orange">
      Storefront shell demo
    </p>
    <h1 class="mt-2 font-display text-display font-black uppercase leading-none tracking-tight text-ink">
      The wall is up.
    </h1>
    <p class="mt-4 max-w-prose text-body-lg text-muted-foreground">
      This page verifies the storefront shell: header, footer, mobile nav,
      cart drawer, and view transitions. Open the cart button in the header
      to see the drawer. Navigate to another page to see view transitions.
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/demo"
        class="border-2 border-ink bg-orange px-6 py-3 text-sm font-black uppercase tracking-wide text-ink shadow-hard-lg transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-hard"
      >
        Reload this page
      </a>
      <a
        href="/"
        class="border-2 border-ink bg-card px-6 py-3 text-sm font-black uppercase tracking-wide text-ink shadow-hard-lg transition-all hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-hard"
      >
        Go home
      </a>
    </div>
  </section>
</StorefrontLayout>
