---
/**
 * "Why IEMs" educational teaser — zine-styled, punchy.
 * Explains what IEMs are and why they beat stock earbuds.
 * Links to /products.
 */

const points = [
  {
    num: "01",
    title: "What's an IEM?",
    body: "In-ear monitor. A tiny pro-grade speaker that seats in your ear canal. Originally built for stage musicians so they could hear themselves over the band.",
  },
  {
    num: "02",
    title: "Why not earbuds?",
    body: "Stock buds sit outside the canal and leak bass. IEMs seal it in — deeper low end, cleaner detail, and the city stays out.",
  },
  {
    num: "03",
    title: "Fit is everything",
    body: "Foam or silicone tips lock the shell in place. Better seal, better bass, better isolation. Your ears are the cabinet.",
  },
];
---

<section
  id="why-iems"
  class="relative border-b-4 border-ink bg-ink bg-noise scroll-mt-20"
  aria-labelledby="why-iems-title"
>
  {/* Hazard stripe top accent */}
  <div class="absolute left-0 right-0 top-0 h-2 bg-hazard-stripes" aria-hidden="true"></div>

  <div class="mx-auto max-w-screen-2xl px-4 py-16 lg:px-8 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_1.4fr] lg:gap-16">
      {/* Left — headline + CTA */}
      <div class="relative">
        <span
          class="inline-block -rotate-1 border-2 border-ink bg-yellow px-3 py-1 text-micro font-black uppercase tracking-widest text-ink shadow-hard-sm"
        >
          The 60-second pitch
        </span>
        <h2
          id="why-iems-title"
          class="mt-4 font-display font-black uppercase leading-[0.86] tracking-tight text-newsprint"
          style="font-size: var(--text-display);"
        >
          Why IEMs
        </h2>
        <p class="mt-5 max-w-md text-body-lg font-medium leading-relaxed text-newsprint/70">
          You don't need a stack of gear or a recording contract. You need a
          seal, a driver, and something worth listening to.
        </p>
        <a
          href="/products?category=iems"
          class="mt-7 inline-flex items-center gap-2 border-2 border-newsprint bg-orange px-6 py-3.5 text-sm font-black uppercase tracking-wider text-ink shadow-hard-lg transition-all hover:-rotate-1 hover:bg-orange-dark hover:shadow-hard active:translate-x-[3px] active:translate-y-[3px] active:shadow-none"
        >
          Browse IEMs
          <span aria-hidden="true">→</span>
        </a>
      </div>

      {/* Right — numbered zine cards */}
      <ol class="flex flex-col gap-4">
        {
          points.map((point, i) => (
            <li
              class="group relative border-4 border-newsprint/30 bg-newsprint p-5 shadow-hard-lg transition-all hover:border-orange"
              style={`transform: rotate(${i % 2 === 0 ? "0.6deg" : "-0.6deg"});`}
            >
              <div class="flex items-start gap-4">
                <span class="font-display text-3xl font-black leading-none text-orange">
                  {point.num}
                </span>
                <div class="min-w-0">
                  <h3 class="font-display text-heading-lg font-black uppercase tracking-tight text-ink">
                    {point.title}
                  </h3>
                  <p class="mt-1.5 text-body font-medium leading-relaxed text-ink-muted">
                    {point.body}
                  </p>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
