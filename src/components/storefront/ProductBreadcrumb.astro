---
/**
 * Grunge breadcrumb for product detail pages.
 * Renders: Home > Category > Brand > Product name
 * Stamped tape-strip styling with torn edges.
 */

interface Crumb {
  label: string;
  href: string | null;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="relative z-10 mb-6 -rotate-1">
  <ol class="flex flex-wrap items-center gap-2">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {item.href ? (
            <a
              href={item.href}
              class="border-2 border-ink bg-tape px-2.5 py-1 font-mono text-micro font-black uppercase tracking-wide text-ink shadow-hard-sm transition-all hover:bg-yellow hover:rotate-1 hover:shadow-hard"
            >
              {item.label}
            </a>
          ) : (
            <span
              aria-current="page"
              class="border-2 border-ink bg-orange px-2.5 py-1 font-mono text-micro font-black uppercase tracking-wide text-ink shadow-hard-sm"
            >
              {item.label}
            </span>
          )}
          {i < items.length - 1 && (
            <span class="text-ink-muted" aria-hidden="true">
              /
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
