---
import { Menu, Search } from "lucide-solid";
import CartButton from "./CartButton.tsx";
import HeaderAuth from "./HeaderAuth.tsx";

const navLinks = [
  { label: "IEMs", href: "/products?category=iems" },
  { label: "DAC amps", href: "/products?category=dac-amps" },
  { label: "Wireless", href: "/products?category=wireless" },
  { label: "All products", href: "/products" },
];
---

<header
  class="sticky top-0 z-40 border-b-4 border-ink bg-newsprint/95 backdrop-blur-sm transition:persist"
  transition:name="header"
  transition:persist
>
  {/* Torn-paper top edge */}
  <div
    class="absolute -top-1 left-0 right-0 h-1 bg-ink"
    style="clip-path: polygon(0% 100%, 2% 60%, 5% 90%, 8% 50%, 12% 85%, 16% 40%, 20% 80%, 25% 55%, 30% 90%, 35% 45%, 40% 85%, 45% 50%, 50% 90%, 55% 40%, 60% 85%, 65% 55%, 70% 90%, 75% 45%, 80% 80%, 84% 50%, 88% 90%, 92% 55%, 96% 85%, 100% 60%, 100% 100%);"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto flex max-w-screen-2xl items-center justify-between gap-3 px-4 py-3 lg:px-8">
    {/* Logo — grunge masthead */}
    <a href="/" class="group flex shrink-0 items-center gap-2" aria-label="Plugged home">
      <div
        class="flex size-10 items-center justify-center border-2 border-ink bg-orange font-display text-xl font-black text-ink shadow-hard-sm transition-all group-hover:rotate-2 group-hover:shadow-hard"
      >
        P
      </div>
      <div class="hidden flex-col leading-none sm:flex">
        <span class="font-display text-xl font-black uppercase tracking-tight text-ink">
          Plugged
        </span>
        <span class="text-micro font-black uppercase tracking-widest text-muted-foreground">
          Private audio supply
        </span>
      </div>
    </a>

    {/* Desktop nav — stencil/spraypaint links */}
    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class:list={[
            "border-2 border-transparent px-3 py-2 text-caption font-black uppercase tracking-wide text-ink transition-all hover:border-ink hover:bg-yellow hover:shadow-hard-sm",
            i % 2 === 0 ? "hover:-rotate-1" : "hover:rotate-1",
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    {/* Right actions */}
    <div class="flex items-center gap-2">
      {/* Auth cluster — sign-in / profile / logout (SolidJS island) */}
      <HeaderAuth client:idle />

      {/* Search trigger — opens the search overlay.
          The overlay itself uses fade-in (backdrop) + slide-down (input)
          keyframes from global.css. Full search wiring lands in issue #12. */}
      <button
        type="button"
        aria-label="Search"
        class="flex size-11 items-center justify-center border-2 border-ink bg-card shadow-hard-sm transition-all hover:bg-cyan hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none active:translate-x-[2px] active:translate-y-[2px]"
        data-search-toggle
      >
        <Search class="size-5" />
      </button>

      {/* Cart button — SolidJS island */}
      <CartButton client:idle />

      {/* Mobile hamburger — opens mobile nav */}
      <button
        type="button"
        aria-label="Open menu"
        class="flex size-11 items-center justify-center border-2 border-ink bg-card shadow-hard-sm transition-all hover:bg-primary hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none md:hidden"
        data-mobile-menu-toggle
      >
        <Menu class="size-5" />
      </button>
    </div>
  </div>

  {/* Mobile menu overlay — flyer wall style */}
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 hidden flex-col bg-newsprint bg-noise md:hidden"
    data-mobile-menu
  >
    <div class="flex items-center justify-between border-b-4 border-ink bg-hazard-stripes p-4">
      <span class="font-display text-2xl font-black uppercase tracking-tight text-ink">
        Menu
      </span>
      <button
        type="button"
        aria-label="Close menu"
        class="flex size-10 items-center justify-center border-2 border-ink bg-newsprint shadow-hard-sm"
        data-mobile-menu-close
      >
        <span class="text-xl font-black">×</span>
      </button>
    </div>
    <nav class="flex flex-col gap-2 p-4" aria-label="Mobile primary">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class:list={[
            "border-2 border-ink bg-card px-4 py-4 text-heading font-black uppercase tracking-tight shadow-hard-sm transition-all active:translate-x-[2px] active:translate-y-[2px] active:shadow-none",
            i % 2 === 0 ? "-rotate-1" : "rotate-1",
          ]}
          data-mobile-menu-link
        >
          {link.label}
        </a>
      ))}
      <a
        href="/auth/sign-in"
        class="border-2 border-ink bg-orange px-4 py-4 text-heading font-black uppercase tracking-tight text-ink shadow-hard-sm transition-all active:translate-x-[2px] active:translate-y-[2px] active:shadow-none -rotate-1"
        data-mobile-menu-link
      >
        Sign in
      </a>
      <a
        href="/track"
        class="border-2 border-ink bg-card px-4 py-4 text-heading font-black uppercase tracking-tight shadow-hard-sm transition-all active:translate-x-[2px] active:translate-y-[2px] active:shadow-none rotate-1"
        data-mobile-menu-link
      >
        Track order
      </a>
    </nav>
  </div>

  {/* Search overlay — fade-in backdrop + slide-down input panel.
      Full search wiring lands in issue #12; this is the animated shell. */}
  <div
    id="search-overlay"
    class="animate-fade-in fixed inset-0 z-50 hidden flex-col bg-ink/50 backdrop-blur-sm"
    data-search-overlay
  >
    <div
      class="animate-slide-down border-b-4 border-ink bg-newsprint-2 bg-noise p-4 shadow-hard-lg"
    >
      <div class="mx-auto flex max-w-screen-2xl items-center gap-3">
        <Search class="size-6 shrink-0 text-ink" />
        <input
          type="search"
          placeholder="Search the wall…"
          class="flex-1 border-2 border-ink bg-newsprint px-4 py-3 font-display text-2xl font-black uppercase tracking-tight text-ink placeholder:text-ink-muted/50 focus:outline-none focus:shadow-hard-sm"
          data-search-input
          aria-label="Search products"
        />
        <button
          type="button"
          aria-label="Close search"
          class="flex size-11 shrink-0 items-center justify-center border-2 border-ink bg-newsprint shadow-hard-sm transition-all hover:bg-pink hover:text-newsprint active:translate-x-[1px] active:translate-y-[1px] active:shadow-none"
          data-search-close
        >
          <span class="text-xl font-black">×</span>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const menu = document.getElementById("mobile-menu");
    const toggle = document.querySelector("[data-mobile-menu-toggle]");
    const close = document.querySelector("[data-mobile-menu-close]");
    const links = document.querySelectorAll("[data-mobile-menu-link]");
    if (!menu || !toggle) return;

    function open() {
      menu.classList.remove("hidden");
      menu.classList.add("flex");
      document.body.style.overflow = "hidden";
    }
    function closeMenu() {
      menu.classList.add("hidden");
      menu.classList.remove("flex");
      document.body.style.overflow = "";
    }

    toggle.addEventListener("click", open);
    close?.addEventListener("click", closeMenu);
    links.forEach((link) => link.addEventListener("click", closeMenu));
  }

  function setupSearchOverlay() {
    const overlay = document.getElementById("search-overlay");
    const toggle = document.querySelector("[data-search-toggle]");
    const close = document.querySelector("[data-search-close]");
    const input = document.querySelector("[data-search-input]");
    if (!overlay || !toggle) return;

    function open() {
      overlay.classList.remove("hidden");
      overlay.classList.add("flex");
      document.body.style.overflow = "hidden";
      // Focus the input after the slide-down animation starts.
      requestAnimationFrame(() => input?.focus());
    }
    function closeSearch() {
      overlay.classList.add("hidden");
      overlay.classList.remove("flex");
      document.body.style.overflow = "";
    }

    toggle.addEventListener("click", open);
    close?.addEventListener("click", closeSearch);
    // Click on the backdrop (not the panel) closes the overlay.
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeSearch();
    });
    // Escape closes.
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !overlay.classList.contains("hidden")) closeSearch();
    });
  }

  // Re-bind on Astro View Transition page swaps
  document.addEventListener("astro:page-load", setupMobileMenu);
  document.addEventListener("astro:page-load", setupSearchOverlay);
</script>
